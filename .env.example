# Flask Environment
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Firebase Configuration
# Download your Firebase service account key from Firebase Console and place it in backend/config/
# Then set the path below (relative to where you run the app from)
FIREBASE_SERVICE_ACCOUNT_KEY=config/serviceAccountKey.json

# Firebase project settings
FIREBASE_STORAGE_BUCKET=d-cart-66ba5.appspot.com

# Optional: Add any other API keys here (if you add more services in future)
# STRIPE_API_KEY=your-stripe-key-here
# PAYPAL_API_KEY=your-paypal-key-here
